{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "dist-worker",
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/worker", "src/shared"]
}
